# Copy this file to ".env" and fill in your keys.
# Only FRED_API_KEY is required. The others are optional and add more news sources.

# REQUIRED (free): https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# OPTIONAL (free tiers) — extra news sources. Leave blank to skip.
# NYT: https://developer.nytimes.com/  (Top Stories API)
NYT_API_KEY=
# Marketaux financial news: https://www.marketaux.com/
MARKETAUX_API_KEY=
# Finnhub market news: https://finnhub.io/
FINNHUB_API_KEY=
